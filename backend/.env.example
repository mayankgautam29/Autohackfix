# Copy to .env and fill in. Never commit .env.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Comma-separated browser origins (no trailing slashes). Production example:
# CORS_ORIGINS=https://autohackfix.vercel.app,http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# production enables stricter HTTP headers on the API
# APP_ENV=production

# Optional: path prefix behind a reverse proxy (no trailing slash), e.g. /api
# ROOT_PATH=/api
